# ─────────────────────────────────────────────
# MAS Pipeline Sentinel — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# LLM
ANTHROPIC_API_KEY=sk-ant-...

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RAW_SIGNALS=pipeline.signals.raw
KAFKA_TOPIC_ANOMALIES=agents.anomalies
KAFKA_TOPIC_INCIDENTS=agents.confirmed_incidents
KAFKA_TOPIC_ACTIONS=agents.actions_taken
KAFKA_TOPIC_HEARTBEATS=agents.heartbeats

# PostgreSQL (Agent State Store)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mas_sentinel
POSTGRES_USER=mas_user
POSTGRES_PASSWORD=changeme

# dbt Artifact Store (local or S3)
DBT_ARTIFACTS_PATH=./dbt_integration/artifacts
# For S3: DBT_ARTIFACTS_PATH=s3://your-bucket/dbt-artifacts

# AWS (optional, for production deployment)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Alerting (optional)
SLACK_WEBHOOK_URL=
PAGERDUTY_API_KEY=

# Agent Configuration
AGENT_MODE=shadow        # shadow | alert_only | supervised | full_autonomy
ANOMALY_ZSCORE_THRESHOLD=2.5
HEARTBEAT_INTERVAL_SECONDS=60
LLM_MODEL_REASONING=claude-sonnet-4-20250514
LLM_MODEL_CLASSIFICATION=claude-haiku-4-5-20251001
